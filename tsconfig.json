{
    "compilerOptions": {
        "declaration": true,
        "outDir": "dist",
        "rootDir": "src",
        "module": "commonjs",
        // Modern browsers support all ES6 features, so ES6 is a good choice. 
        "target": "es6",
        "esModuleInterop": true,
        "sourceMap": true,
        "strict": true,
        "types": ["node", "jest"]
    },
    "include": ["src/**/*"],
    "exclude": [
        "node_modules"
    ]
}